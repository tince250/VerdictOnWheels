                            </ruleml:Expr>
                        </ruleml:Atom>
                        <ruleml:Atom>
                            <ruleml:Expr>
                                <ruleml:Fun>&lt;</ruleml:Fun>
                                <ruleml:Var>speed_over</ruleml:Var>
                                <ruleml:Ind>71</ruleml:Ind>
                            </ruleml:Expr>
