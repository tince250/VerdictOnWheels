        </lrml:PrescriptiveStatement>

        <!-- Alcohol with accident -->
        <lrml:PrescriptiveStatement key="ps6">
            <ruleml:Rule key=":rule6" closure="universal" strength="defeasible">
                <ruleml:if>
                    <ruleml:And>
                        <ruleml:Atom><ruleml:Rel iri="lc:alcohol_level"/><ruleml:Var type="lc:defendant">Defendant</ruleml:Var><ruleml:Var>alcohol_level</ruleml:Var></ruleml:Atom>
                        <ruleml:Atom><ruleml:Expr><ruleml:Fun>&gt;</ruleml:Fun><ruleml:Var>alcohol_level</ruleml:Var><ruleml:Ind>0.4</ruleml:Ind></ruleml:Expr></ruleml:Atom>
                        <ruleml:Atom><ruleml:Expr><ruleml:Fun>&lt;</ruleml:Fun><ruleml:Var>alcohol_level</ruleml:Var><ruleml:Ind>1.1</ruleml:Ind></ruleml:Expr></ruleml:Atom>
