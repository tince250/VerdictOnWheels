                <ruleml:if><ruleml:Atom><ruleml:Rel>rural_road_speed_violation_lv1_accident_cl_37</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var></ruleml:Atom></ruleml:if>
                <ruleml:then><ruleml:Atom><ruleml:Rel>to_pay_max</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var><ruleml:Ind>400</ruleml:Ind></ruleml:Atom></ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <lrml:PrescriptiveStatement key="psp13_ban">
            <ruleml:Rule key=":pen_ps13_ban" closure="universal" strength="defeasible">
                <ruleml:if><ruleml:Atom><ruleml:Rel>rural_road_speed_violation_lv1_accident_cl_37</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var></ruleml:Atom></ruleml:if>
                <ruleml:then><ruleml:Atom><ruleml:Rel>driving_ban</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var><ruleml:Ind>3</ruleml:Ind></ruleml:Atom></ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <lrml:PrescriptiveStatement key="psp14_min">
            <ruleml:Rule key=":pen_ps14_min" closure="universal" strength="defeasible">
                <ruleml:if><ruleml:Atom><ruleml:Rel>rural_road_speed_violation_lv2_accident_cl_37</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var></ruleml:Atom></ruleml:if>
                <ruleml:then><ruleml:Atom><ruleml:Rel>to_pay_min</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var><ruleml:Ind>300</ruleml:Ind></ruleml:Atom></ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <lrml:PrescriptiveStatement key="psp14_max">
            <ruleml:Rule key=":pen_ps14_max" closure="universal" strength="defeasible">
                <ruleml:if><ruleml:Atom><ruleml:Rel>rural_road_speed_violation_lv2_accident_cl_37</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var></ruleml:Atom></ruleml:if>
                <ruleml:then><ruleml:Atom><ruleml:Rel>to_pay_max</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var><ruleml:Ind>1000</ruleml:Ind></ruleml:Atom></ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <lrml:PrescriptiveStatement key="psp14_ban">
            <ruleml:Rule key=":pen_ps14_ban" closure="universal" strength="defeasible">
                <ruleml:if><ruleml:Atom><ruleml:Rel>rural_road_speed_violation_lv2_accident_cl_37</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var></ruleml:Atom></ruleml:if>
                <ruleml:then><ruleml:Atom><ruleml:Rel>driving_ban</ruleml:Rel><ruleml:Var type=":defendant">Defendant</ruleml:Var><ruleml:Ind>3</ruleml:Ind></ruleml:Atom></ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- === OVERRIDES: ensure correct precedence (accident > non-accident, higher lv > lower lv) === -->

        <!-- town: accident rules override non-accident -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps3" over="#ps1"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps9" over="#ps7"/>
        </lrml:OverrideStatement>

        <!-- alcohol accident overrides speed accident (alcohol more severe) -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps6" over="#ps3"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps6" over="#ps9"/>
        </lrml:OverrideStatement>

        <!-- existing basic overrides -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps7" over="#ps1"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps5" over="#ps1"/>
        </lrml:OverrideStatement>

        <!-- specific injury/damage accident rules override generic accident -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps16" over="#ps3"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps17" over="#ps3"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps18" over="#ps3"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps19" over="#ps3"/>
        </lrml:OverrideStatement>

        <!-- rural: accident rules override non-accident -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps13" over="#ps11"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps14" over="#ps12"/>
        </lrml:OverrideStatement>

        <!-- rural basic overrides -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps12" over="#ps11"/>
        </lrml:OverrideStatement>

        <!-- alcohol accident overrides rural speed accidents too -->
        <lrml:OverrideStatement>
            <lrml:Override under="#ps6" over="#ps13"/>
        </lrml:OverrideStatement>

        <lrml:OverrideStatement>
            <lrml:Override under="#ps6" over="#ps14"/>
        </lrml:OverrideStatement>
    </lrml:Statements>
</lrml:LegalRuleML>