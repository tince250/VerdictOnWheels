        <!-- town 50-60 with accident + damage_eur > 20000 -->
        <lrml:PrescriptiveStatement key="ps19">
            <ruleml:Rule key=":rule19" closure="universal" strength="defeasible">
                <ruleml:if>
                    <ruleml:And>
